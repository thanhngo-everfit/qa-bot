# ── Slack ──────────────────────────────────────
# From: api.slack.com/apps → your QABot app → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx

# From: api.slack.com/apps → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Anthropic ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── Jira ────────────────────────────────────────
JIRA_EMAIL=your-email@everfit.io
JIRA_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Server ──────────────────────────────────────
# Use 3001 to avoid conflict with BugBot (3000)
PORT=3001
